{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@sharelyai/widget-services": ["packages/services/src"],
      "@sharelyai/widget-services/*": ["packages/services/src/*"],
      "@sharelyai/widget-ui-shared": ["packages/ui-shared/src"],
      "@sharelyai/widget-ui-shared/*": ["packages/ui-shared/src/*"],
      "@sharelyai/widget-ui-chat": ["packages/ui-chat/src"],
      "@sharelyai/widget-ui-chat/*": ["packages/ui-chat/src/*"],
      "@sharelyai/widget-ui-search": ["packages/ui-search/src"],
      "@sharelyai/widget-ui-search/*": ["packages/ui-search/src/*"],
      "@sharelyai/widget-ui-browse": ["packages/ui-browse/src"],
      "@sharelyai/widget-ui-browse/*": ["packages/ui-browse/src/*"],
      "@sharelyai/widget-ui-agent-chat": ["packages/ui-agent-chat/src"],
      "@sharelyai/widget-ui-agent-chat/*": ["packages/ui-agent-chat/src/*"]
    }
  }
}