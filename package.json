{
  "name": "sharely-webcontrol",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "dev:widget": "turbo run dev --filter=@sharelyai/widget",
    "dev:all": "turbo run build && turbo run dev",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "17.6.0",
    "prettier": "3.9.6",
    "tsup": "8.5.1",
    "turbo": "2.8.14",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "vite": "7.3.1"
  },
  "engines": {
    "node": "24.x",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
