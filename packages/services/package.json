{
  "name": "@sharelyai/widget-services",
  "version": "0.0.1",
  "author": "Sharely AI",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.41",
    "@tanstack/react-query": "5.90.21",
    "ai": "6.0.68",
    "js-cookie": "3.0.5",
    "jwt-decode": "4.0.0",
    "yup": "1.7.1",
    "zustand": "5.0.11"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@types/js-cookie": "3.0.6",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "jsdom": "28.1.0",
    "react": "19.2.4",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}