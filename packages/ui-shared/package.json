{
  "name": "@sharelyai/widget-ui-shared",
  "version": "0.0.1",
  "author": "Sharely AI",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "styled-components": "^6.0.0"
  },
  "dependencies": {
    "@floating-ui/react": "0.27.19",
    "@sharelyai/widget-services": "workspace:*",
    "react-content-loader": "7.1.2",
    "zustand": "5.0.11",
    "react-perfect-scrollbar": "1.5.8",
    "react-markdown": "10.1.0",
    "remark-emoji": "5.0.2",
    "remark-gfm": "4.0.1",
    "rehype-raw": "7.0.0",
    "@react-pdf-viewer/core": "3.12.0",
    "@react-pdf-viewer/default-layout": "3.12.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "styled-components": "6.3.11",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "@types/mdast": "4.0.4"
  }
}
